# Database (Neon PostgreSQL)
# Create a project at https://console.neon.tech → Connection details → copy the pooled URL
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Brevo transactional email (sender domain must be verified in Brevo)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=hello@mainlandbuildinginspections.co.nz
BREVO_SENDER_NAME=Mainland Building Inspections
BUSINESS_NOTIFICATION_EMAIL=office@mainlandbuildinginspections.co.nz
# Test after setup: npm run email:test

# Staff dashboard (hidden URL — not linked on public site)
STAFF_EMAIL=office@mainlandbuildinginspections.co.nz
STAFF_PASSWORD=change-me-min-8-chars
STAFF_NAME=Office
# Or use bcrypt hash instead of plain password (legacy env login only):
# STAFF_PASSWORD_HASH=
STAFF_SESSION_SECRET=generate-a-random-string-at-least-32-characters-long
# After DATABASE_URL is set: npm run db:migrate && npm run staff:seed

# Public site — MUST match your live primary domain exactly (include www if that is what works)
NEXT_PUBLIC_SITE_URL=https://www.mainlandbuildinginspections.co.nz
NEXT_PUBLIC_BUSINESS_PHONE=03 000 0000
NEXT_PUBLIC_BUSINESS_EMAIL=hello@mainlandbuildinginspections.co.nz
# Google Search Console verification (HTML tag method — paste the content value only)
# GOOGLE_SITE_VERIFICATION=
# Optional: custom Google Maps embed URL for service area map
# NEXT_PUBLIC_SERVICE_AREA_MAP_EMBED=
