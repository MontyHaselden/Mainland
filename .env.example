# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Brevo transactional email
BREVO_API_KEY=
BREVO_SENDER_EMAIL=hello@mainlandinspections.co.nz
BREVO_SENDER_NAME=Mainland Building Inspections
BUSINESS_NOTIFICATION_EMAIL=office@mainlandinspections.co.nz

# Staff dashboard (hidden URL — not linked on public site)
STAFF_EMAIL=office@mainlandinspections.co.nz
STAFF_PASSWORD=change-me-min-8-chars
# Or use bcrypt hash instead of plain password:
# STAFF_PASSWORD_HASH=
STAFF_SESSION_SECRET=generate-a-random-string-at-least-32-characters-long

# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BUSINESS_PHONE=03 000 0000
NEXT_PUBLIC_BUSINESS_EMAIL=hello@mainlandinspections.co.nz
